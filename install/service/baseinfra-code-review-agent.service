# BaseInfra code-review agent — Linux reboot-survival (stage 1 of 2).
#
# Type=oneshot + RemainAfterExit=yes: the unit counts as "active" once the
# stage-2 readiness wrapper (__BOOT_SCRIPT__) has brought the compose stack up
# and exited 0. Ordering: After/Wants docker.service so the engine is up first,
# network-online so tailscale can hand out an address. Per-container liveness
# after bring-up is Docker's `restart: unless-stopped`, not systemd's. The
# installer renders the placeholders below, installs this to /etc/systemd/system,
# then `systemctl enable --now`.

[Unit]
Description=BaseInfra code-review agent (docker compose stack)
Documentation=https://github.com/basedinfra/code-review-agent
# Soft dependency only (Wants/After, NOT Requires): a `systemctl restart docker`
# must not propagate a stop to this unit — that would run ExecStop and mark the
# containers manually stopped, defeating Docker's own `restart: unless-stopped`.
Wants=docker.service network-online.target
After=docker.service network-online.target tailscaled.service

[Service]
Type=oneshot
RemainAfterExit=yes
User=__SERVICE_USER__
# /usr/bin/env bash (not /bin/bash): some systemd distros (NixOS, Alpine, minimal
# containers) have no /bin/bash. Paths are quoted so an INSTALL_DIR with spaces
# isn't split across argv by systemd's command-line parser.
ExecStart=/usr/bin/env bash "__BOOT_SCRIPT__" "__INSTALL_DIR__"
# $$1 (not $1): systemd expands $/${} in Exec lines before sh sees them, so a bare
# $1 would be eaten; $$ passes a literal $ through to the positional parameter.
ExecStop=/bin/sh -c 'cd "$$1" && docker compose stop' sh "__INSTALL_DIR__"
# Headroom: agent-boot.sh may spend up to DOCKER_WAIT_SECS + TAILSCALE_WAIT_SECS
# (~300s) on readiness waits before `docker compose up -d`, so the start timeout
# must exceed that plus image-pull time — otherwise systemd marks the oneshot
# failed right as the readiness gate succeeds.
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target
