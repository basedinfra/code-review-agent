#!/usr/bin/env bash
# BaseInfra BYO code-review agent installer.
#
# Detects OS/arch, installs Tailscale, joins the tailnet, brings up the agent +
# socket-proxy via docker compose, waits for /health, runs the one-shot register,
# and installs a reboot-survival service (launchd LaunchAgent on macOS, systemd
# unit on Linux) that re-brings-up the stack on boot.
#
# SECRETS: the bootstrap token and the Tailscale pre-auth key are read from env
# or prompted on the controlling terminal — never passed as argv (visible in
# `ps`). The bootstrap token is written to a 0600 env-file.
#
# Required env:
#   BACKEND_ID     code_review_backends row id (advertised as tag:backend-<id>)
#   LOGIN_SERVER   https://headscale.<domain>:8443
#   DASHBOARD_URL  https://dashboard.<domain>
# Secret env (else prompted on the controlling terminal):
#   TS_AUTHKEY     Tailscale pre-auth key (single-use, <=15 min)
#   BISESS_TOKEN   bootstrap token (bisess_…)   [alias: BACKEND_BOOTSTRAP_TOKEN]
# Optional env:
#   AGENT_HOSTNAME         tailnet hostname (default: code-review-<BACKEND_ID>)
#   INSTALL_DIR            default: $HOME/.baseinfra/code-review-agent
#   INSTALL_SERVICE        1 = install reboot-survival service (default), 0 = skip
#   REF                    git ref for fetching repo assets (default: main)
#   IMAGE_TAG              docker image tag (default: v1)
#   AGENT_PORT             agent HTTP port (default: 7777)
#   CODE_REVIEW_AGENT_IMAGE, PR_AGENT_IMAGE, PR_AGENT_PLATFORM, DEV_LOCAL_COMPOSE
#
# Flags:
#   --dry-run      Print every step without making changes (no secrets needed).
#   --no-service   Don't install the launchd/systemd reboot-survival service.
#   --help         Show usage.
#
# NETWORKING (Phase 4): the agent uses `network_mode: host` to bind the host's
# tailnet IP. That works on Linux and OrbStack; native macOS Docker Desktop
# mediates host networking through its VM and cannot bind the host tailscale
# interface, so the production macOS networking model (OrbStack, or tailscale in
# a sidecar) is validated in Sprint 4 Phase 4. See README "Security model".
set -euo pipefail

REPO_RAW='https://raw.githubusercontent.com/basedinfra/code-review-agent'
# Git ref for fetching repo assets (docker-compose.yml, the service files) — a
# real branch/tag, distinct from the Docker image tag, which is published as :v1
# from a SemVer git tag (e.g. v1.0.0); there is no git ref named "v1". Pin REF to
# a release tag for reproducibility.
REF="${REF:-main}"
IMAGE_TAG="${IMAGE_TAG:-v1}"
INSTALL_DIR="${INSTALL_DIR:-$HOME/.baseinfra/code-review-agent}"
AGENT_PORT="${AGENT_PORT:-7777}"
# Set by flags / env at the bottom of the file, before main() runs.
DRY_RUN="${DRY_RUN:-0}"
INSTALL_SERVICE="${INSTALL_SERVICE:-1}"

log() { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
log_dry() { printf '\033[1;33m[dry-run]\033[0m %s\n' "$*"; }
die() { printf '\033[1;31mERROR:\033[0m %s\n' "$*" >&2; exit 1; }

usage() {
	cat <<'EOF'
BaseInfra BYO code-review agent installer.

Usage:
  install/agent [--dry-run] [--no-service] [--help]
  curl -fsSL .../install/agent | BACKEND_ID=.. LOGIN_SERVER=.. DASHBOARD_URL=.. bash

Required env:
  BACKEND_ID     code_review_backends row id (advertised as tag:backend-<id>)
  LOGIN_SERVER   https://headscale.<domain>:8443
  DASHBOARD_URL  https://dashboard.<domain>

Secret env (else prompted on the controlling terminal):
  TS_AUTHKEY     Tailscale pre-auth key (single-use, <=15 min)
  BISESS_TOKEN   bootstrap token (bisess_…)   [alias: BACKEND_BOOTSTRAP_TOKEN]

Options:
  --dry-run      Print every step without making changes (no secrets needed).
  --no-service   Don't install the launchd/systemd reboot-survival service
                 (alias: INSTALL_SERVICE=0).
  --help         Show this help.

Optional env: AGENT_HOSTNAME, INSTALL_DIR, REF, IMAGE_TAG, AGENT_PORT,
  CODE_REVIEW_AGENT_IMAGE, PR_AGENT_IMAGE, PR_AGENT_PLATFORM, DEV_LOCAL_COMPOSE.
EOF
}

# Tailscale state changes (`up`) require root on Linux AND on the macOS Homebrew
# install; prefix with sudo whenever we are not already root.
ts_sudo() {
	if [ "$(id -u)" -ne 0 ]; then
		sudo "$@"
	else
		"$@"
	fi
}

require_env() {
	local name="$1"
	[ -n "${!name:-}" ] || die "missing required env: $name"
}

detect_platform() {
	local os arch
	os="$(uname -s)"
	arch="$(uname -m)"
	case "$os" in
		Darwin) OS='darwin' ;;
		Linux) OS='linux' ;;
		*) die "unsupported OS: $os (need Darwin or Linux)" ;;
	esac
	case "$arch" in
		arm64 | aarch64) ARCH='arm64' ;;
		x86_64 | amd64) ARCH='x86_64' ;;
		*) die "unsupported arch: $arch (need arm64 or x86_64)" ;;
	esac
	log "platform: $OS/$ARCH"
}

ensure_docker() {
	if [ "$DRY_RUN" = '1' ]; then
		log_dry "verify docker + docker compose v2 are installed"
		return
	fi
	command -v docker >/dev/null 2>&1 || die "docker not found — install Docker (Desktop/OrbStack/Engine) first"
	docker compose version >/dev/null 2>&1 || die "docker compose v2 not found"
}

ensure_tailscale() {
	if [ "$DRY_RUN" = '1' ]; then
		log_dry "ensure tailscale is installed and tailscaled is running"
		return
	fi
	if ! command -v tailscale >/dev/null 2>&1; then
		if [ "$OS" = 'linux' ]; then
			log "installing Tailscale (official script)"
			curl -fsSL https://tailscale.com/install.sh | sh
		elif command -v brew >/dev/null 2>&1; then
			log "installing Tailscale via Homebrew"
			brew install tailscale
		else
			die "Tailscale not installed. On macOS install it from https://tailscale.com/download, then re-run."
		fi
	else
		log "tailscale already installed"
	fi
	# macOS: ensure tailscaled is running before `tailscale up`. Homebrew installs
	# it stopped, and an existing CLI install may also have a stopped daemon — so
	# this runs on BOTH the fresh-install and already-installed paths. Best-effort.
	# (macOS host networking for the agent itself is a Phase-4 item — see README.)
	if [ "$OS" = 'darwin' ]; then
		log "ensuring tailscaled is running (macOS)"
		sudo tailscaled install-system-daemon 2>/dev/null ||
			sudo brew services start tailscale 2>/dev/null ||
			log "WARNING: could not auto-start tailscaled — start it manually, then re-run"
	fi
}

tailscale_up() {
	local hostname="${AGENT_HOSTNAME:-code-review-${BACKEND_ID}}"
	local tags="tag:backend-${BACKEND_ID},tag:baseinfra-agent"
	log "joining tailnet via ${LOGIN_SERVER} as ${hostname} (${tags})"
	if [ "$DRY_RUN" = '1' ]; then
		# Show the shape only — never print the pre-auth key.
		log_dry "tailscale up --login-server=$LOGIN_SERVER --hostname=$hostname --advertise-tags=$tags --authkey=<redacted> --accept-routes"
		return
	fi
	# NOTE: `tailscale up` has NO non-argv way to supply the key — no stdin, env,
	# or file: input (verified against the Tailscale CLI docs; only `tailscale
	# login` honors file:). The key is therefore briefly visible in this child
	# process's argv via `ps` during the join. The mitigation is single-use,
	# <=15-min pre-auth keys (the dashboard clamps them), so a key seen in argv is
	# already spent/expired. The installer itself never takes the key as argv — it
	# is read via stdin/env (see main()).
	ts_sudo tailscale up \
		--login-server="$LOGIN_SERVER" \
		--authkey="$TS_AUTHKEY" \
		--hostname="$hostname" \
		--advertise-tags="$tags" \
		--accept-routes
}

write_env() {
	local env_file="$INSTALL_DIR/agent.env"
	if [ "$DRY_RUN" = '1' ]; then
		log_dry "write $env_file (0600): BACKEND_ID, DASHBOARD_URL, BACKEND_BOOTSTRAP_TOKEN=<redacted>"
		return
	fi
	mkdir -p "$INSTALL_DIR"
	# Scope the restrictive umask to a subshell so it does not persist into the
	# rest of the installer; printf (not echo) so a token containing shell-special
	# characters cannot corrupt the file.
	(
		umask 077
		{
			printf 'BACKEND_BOOTSTRAP_TOKEN=%s\n' "$BISESS_TOKEN"
			printf 'DASHBOARD_URL=%s\n' "$DASHBOARD_URL"
			printf 'BACKEND_ID=%s\n' "$BACKEND_ID"
		} >"$env_file"
	)
	chmod 600 "$env_file"
	log "wrote $env_file (0600)"
}

# Fetch a repo asset (the compose file, the boot wrapper, or a service template)
# to a dest path. By default pulls the pinned file from the repo at $REF; a stray
# local file is used ONLY under an explicit DEV_LOCAL_COMPOSE=1 opt-in (named for
# its original compose-only use — it now gates every asset fetch), so a
# `curl|bash` install never picks up cwd files.
fetch_asset() {
	local rel="$1" dest="$2"
	if [ "$DRY_RUN" = '1' ]; then
		log_dry "fetch $rel -> $dest"
		return
	fi
	mkdir -p "$(dirname "$dest")"
	if [ "${DEV_LOCAL_COMPOSE:-}" = '1' ] && [ -f "./$rel" ]; then
		log "using local ./$rel (DEV_LOCAL_COMPOSE=1)"
		cp "./$rel" "$dest"
	else
		log "fetching $rel @ ${REF}"
		curl -fsSL "${REPO_RAW}/${REF}/${rel}" -o "$dest"
	fi
}

fetch_compose() { fetch_asset 'docker-compose.yml' "$INSTALL_DIR/docker-compose.yml"; }

compose_up() {
	if [ "$DRY_RUN" = '1' ]; then
		log_dry "write $INSTALL_DIR/.env (CODE_REVIEW_AGENT_IMAGE / PR_AGENT_* / AGENT_PORT)"
		log_dry "(cd $INSTALL_DIR && docker compose pull && docker compose up -d)"
		return
	fi
	log "starting agent + socket-proxy"
	# Persist the compose interpolation vars to .env in the install dir so this
	# run AND any later manual `docker compose up` from that dir resolve the same
	# image/platform/port. (Exporting would apply only to this one invocation —
	# Codex P2; compose auto-reads ./.env for interpolation.)
	{
		printf 'CODE_REVIEW_AGENT_IMAGE=%s\n' "${CODE_REVIEW_AGENT_IMAGE:-ghcr.io/basedinfra/code-review-agent:${IMAGE_TAG}}"
		printf 'PR_AGENT_IMAGE=%s\n' "${PR_AGENT_IMAGE:-codiumai/pr-agent:latest}"
		printf 'PR_AGENT_PLATFORM=%s\n' "${PR_AGENT_PLATFORM:-linux/amd64}"
		printf 'AGENT_PORT=%s\n' "$AGENT_PORT"
	} >"$INSTALL_DIR/.env"
	(
		cd "$INSTALL_DIR"
		docker compose pull
		docker compose up -d
	)
}

wait_health() {
	if [ "$DRY_RUN" = '1' ]; then
		log_dry "wait for agent /health on the tailnet IP:${AGENT_PORT}"
		return
	fi
	local ip
	ip="$(tailscale ip -4 2>/dev/null | head -n1)"
	[ -n "$ip" ] || die "no tailnet IPv4 assigned after tailscale up"
	log "waiting for agent /health on ${ip}:${AGENT_PORT}"
	local attempt=0
	while [ "$attempt" -lt 30 ]; do
		if curl -fsS "http://${ip}:${AGENT_PORT}/health" >/dev/null 2>&1; then
			log "agent healthy"
			return
		fi
		sleep 2
		attempt=$((attempt + 1))
	done
	die "agent /health did not come up; check: (cd $INSTALL_DIR && docker compose logs agent)"
}

do_register() {
	if [ "$DRY_RUN" = '1' ]; then
		log_dry "(cd $INSTALL_DIR && docker compose exec -T agent node src/register.js)  # one-shot register, 409/429 backoff"
		return
	fi
	log "registering with the dashboard"
	local code=0
	(cd "$INSTALL_DIR" && docker compose exec -T agent node src/register.js) || code=$?
	case "$code" in
		0) log "registered — backend should now show 'connected'" ;;
		2) die "registration rejected (bad/expired token); re-pair from the dashboard" ;;
		*) die "registration did not complete; retry: (cd $INSTALL_DIR && docker compose exec -T agent node src/register.js)" ;;
	esac
}

# Install the reboot-survival service: a launchd LaunchAgent (macOS) or a systemd
# unit (Linux) that runs the stage-2 readiness wrapper (agent-boot.sh) at
# login/boot. The wrapper is copied INTO the install dir so the installed service
# is self-contained (it does not depend on a checked-out repo). Per-container
# liveness is Docker's `restart: unless-stopped`; this unit handles the boot kick.
install_service() {
	if [ "$INSTALL_SERVICE" != '1' ]; then
		log "skipping reboot-survival service (--no-service / INSTALL_SERVICE=0)"
		return
	fi
	local boot_dest="$INSTALL_DIR/agent-boot.sh"
	fetch_asset 'install/agent-boot.sh' "$boot_dest"
	[ "$DRY_RUN" = '1' ] || chmod +x "$boot_dest"
	if [ "$OS" = 'darwin' ]; then
		install_service_macos "$boot_dest"
	else
		install_service_linux "$boot_dest"
	fi
}

install_service_macos() {
	local boot_dest="$1"
	local label='com.baseinfra.code-review-agent'
	local plist="$HOME/Library/LaunchAgents/${label}.plist"
	local tmpl="$INSTALL_DIR/${label}.plist"
	local log_file="$INSTALL_DIR/agent-boot.log"
	local uid
	uid="$(id -u)"
	fetch_asset "install/service/${label}.plist" "$tmpl"
	if [ "$DRY_RUN" = '1' ]; then
		log_dry "render LaunchAgent -> $plist, then: launchctl bootout/bootstrap gui/$uid"
		return
	fi
	mkdir -p "$HOME/Library/LaunchAgents"
	sed -e "s#__BOOT_SCRIPT__#${boot_dest}#g" \
		-e "s#__INSTALL_DIR__#${INSTALL_DIR}#g" \
		-e "s#__LOG_FILE__#${log_file}#g" \
		"$tmpl" >"$plist"
	# Reload cleanly: bootout an existing instance (ignore "not loaded"), bootstrap
	# the new one, and enable it so it survives reboots.
	launchctl bootout "gui/${uid}/${label}" 2>/dev/null || true
	launchctl bootstrap "gui/${uid}" "$plist"
	launchctl enable "gui/${uid}/${label}" 2>/dev/null || true
	log "installed LaunchAgent: $plist (logs: $log_file)"
}

install_service_linux() {
	local boot_dest="$1"
	local unit='baseinfra-code-review-agent.service'
	local unit_path="/etc/systemd/system/${unit}"
	local tmpl="$INSTALL_DIR/${unit}"
	local svc_user
	svc_user="$(id -un)"
	fetch_asset "install/service/${unit}" "$tmpl"
	if ! command -v systemctl >/dev/null 2>&1; then
		# No systemd (Alpine/OpenRC, WSL without systemd, …): skip in BOTH modes —
		# the operator starts the wrapper from their own init system. Keep the
		# message dry-run-aware so a preview on a non-systemd host reads honestly.
		local msg="systemctl not found; skipping service install (start manually: bash $boot_dest $INSTALL_DIR)"
		if [ "$DRY_RUN" = '1' ]; then
			log_dry "$msg"
		else
			log "WARNING: $msg"
		fi
		return
	fi
	if [ "$DRY_RUN" = '1' ]; then
		log_dry "render systemd unit -> $unit_path (User=$svc_user), then: systemctl daemon-reload; systemctl enable --now $unit"
		return
	fi
	sed -e "s#__BOOT_SCRIPT__#${boot_dest}#g" \
		-e "s#__INSTALL_DIR__#${INSTALL_DIR}#g" \
		-e "s#__SERVICE_USER__#${svc_user}#g" \
		"$tmpl" | ts_sudo tee "$unit_path" >/dev/null
	ts_sudo systemctl daemon-reload
	ts_sudo systemctl enable --now "$unit"
	log "installed systemd unit: $unit_path"
}

main() {
	require_env BACKEND_ID
	require_env LOGIN_SERVER
	require_env DASHBOARD_URL

	if [ "$DRY_RUN" = '1' ]; then
		log "DRY RUN — printing every step; no changes will be made, no secrets needed"
		TS_AUTHKEY='<redacted>'
		BISESS_TOKEN='<redacted>'
	else
		# Prompt from the controlling terminal, NOT stdin: under the documented
		# `curl ... | bash` install, stdin IS the script pipe, so a plain `read`
		# would consume the script instead of the user's input. With no tty we fall
		# through to the die below (set TS_AUTHKEY / BISESS_TOKEN for non-interactive
		# installs).
		if [ -z "${TS_AUTHKEY:-}" ] && [ -e /dev/tty ]; then
			read -rsp 'Tailscale pre-auth key: ' TS_AUTHKEY </dev/tty && echo
		fi
		# Accept either name; the agent process reads it as BACKEND_BOOTSTRAP_TOKEN.
		BISESS_TOKEN="${BISESS_TOKEN:-${BACKEND_BOOTSTRAP_TOKEN:-}}"
		if [ -z "${BISESS_TOKEN:-}" ] && [ -e /dev/tty ]; then
			read -rsp 'Bootstrap token (bisess_…): ' BISESS_TOKEN </dev/tty && echo
		fi
		[ -n "$TS_AUTHKEY" ] || die "no Tailscale pre-auth key (set TS_AUTHKEY for non-interactive / curl|bash installs)"
		[ -n "$BISESS_TOKEN" ] || die "no bootstrap token (set BISESS_TOKEN or BACKEND_BOOTSTRAP_TOKEN for non-interactive installs)"
	fi

	detect_platform
	ensure_docker
	ensure_tailscale
	tailscale_up
	write_env
	fetch_compose
	compose_up
	wait_health
	do_register
	install_service
	log "done. Reviews run on demand via the tailnet."
}

while [ $# -gt 0 ]; do
	case "$1" in
		--dry-run) DRY_RUN=1 ;;
		--no-service) INSTALL_SERVICE=0 ;;
		-h | --help)
			usage
			exit 0
			;;
		*) die "unknown argument: $1 (try --help)" ;;
	esac
	shift
done

main
