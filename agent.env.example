# Copy to `agent.env` (the installer does this with mode 0600) and fill in.
# agent.env is gitignored — it holds the single-use bootstrap token.

# The single-use bootstrap token (bisess_…) from the dashboard pairing wizard.
BACKEND_BOOTSTRAP_TOKEN=bisess_xxxxxxxxxxxxxxxxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx_xxxxxx

# Dashboard base URL (the register endpoint is derived from it).
DASHBOARD_URL=https://dashboard.example.com

# This backend's id (→ tag:backend-<id>); informational on the agent side.
BACKEND_ID=42

# Local dev/test ONLY — allow RPC calls from loopback in addition to the tailnet.
# Never set this in production; the RPC surface must stay tailnet-only.
# AGENT_ALLOW_LOOPBACK=true
